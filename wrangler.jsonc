{
  "name": "katachi-ai-com",
  "compatibility_date": "2026-06-28",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "katachi-ai.com",
      "custom_domain": true
    },
    {
      "pattern": "www.katachi-ai.com",
      "custom_domain": true
    }
  ],
  "build": {
    "command": "sh scripts/build-cloudflare-pages.sh"
  },
  "assets": {
    "directory": "./dist",
    "html_handling": "auto-trailing-slash",
    "not_found_handling": "none"
  }
}
